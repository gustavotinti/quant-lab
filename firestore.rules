rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Dados privados do dono (ex.: portfólio real do eToro).
    // Escrita só pelo pipeline (Admin SDK / service account, que ignora
    // estas regras). Leitura só pelo dono, logado com o Google.
    match /private/{doc} {
      allow read: if request.auth != null
        && request.auth.token.email == 'gustavo.a.tinti3@gmail.com';
      allow write: if false;
    }

    // Usuários da plataforma: cada um cria/lê o próprio registro no
    // primeiro login; só o ADMIN (dono) lista todos e pode banir.
    function admin() {
      return request.auth != null
        && request.auth.token.email == 'gustavo.a.tinti3@gmail.com';
    }
    match /users/{uid} {
      allow read, write: if admin();
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.banido == false;
      allow read: if request.auth != null && request.auth.uid == uid;
      // o próprio usuário pode atualizar o perfil, mas NUNCA o banimento
      allow update: if request.auth != null && request.auth.uid == uid
        && request.resource.data.banido == resource.data.banido;
    }

    // Todo o resto: fechado (o painel público lê do Hosting, não daqui).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
