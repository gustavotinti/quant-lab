rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Dados privados do dono (ex.: portfólio real do eToro).
    // Escrita só pelo pipeline (Admin SDK / service account, que ignora
    // estas regras). Leitura só pelo dono, logado com o Google.
    match /private/{doc} {
      allow read: if request.auth != null
        && request.auth.token.email == 'gustavo.a.tinti3@gmail.com';
      allow write: if false;
    }

    // Todo o resto: fechado (o painel público lê do Hosting, não daqui).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
